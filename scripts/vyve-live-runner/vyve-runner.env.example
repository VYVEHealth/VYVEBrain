# VYVE simulated-live runner — environment (copy to vyve-runner.env, chmod 600)
# Only the Supabase service key lives here. YouTube OAuth creds + RTMP stream
# keys are read from Supabase Vault at runtime.
VYVE_SUPABASE_URL=https://ixjfklpckgxrwjlfsaaz.supabase.co
VYVE_SUPABASE_SERVICE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
VYVE_MEDIA_DIR=/srv/vyve/masters        # the folder holding the master mp4s
# optional:
# VYVE_REFRESH_INTERVAL=60
# VYVE_SPAWN_HORIZON=900
